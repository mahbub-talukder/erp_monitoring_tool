      "id": 1,
      "type": "table",
      "title": "Server Health Status",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (server,host,instance) (up{job=\"node\", server=~\"$server\", instance=~\"$instance\"})",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "max by (server,host,instance) (node_systemd_unit_state{job=\"node\", server=~\"$server\", instance=~\"$instance\", name=\"docker.service\", state=\"active\"}) or max by (server,host,instance) ((up{job=\"node\", server=~\"$server\", instance=~\"$instance\"} * 0) - 1)",
          "format": "table",
          "instant": true
        },
        {
          "refId": "C",
          "expr": "max by (server,host,instance) (node_systemd_unit_state{job=\"node\", server=~\"$server\", instance=~\"$instance\", name=\"nginx.service\", state=\"active\"}) or max by (server,host,instance) ((up{job=\"node\", server=~\"$server\", instance=~\"$instance\"} * 0) - 1)",
          "format": "table",
          "instant": true
        },
        {
          "refId": "D",
          "expr": "100 - (avg by (server,host,instance) (rate(node_cpu_seconds_total{job=\"node\", server=~\"$server\", instance=~\"$instance\", mode=\"idle\"}[5m])) * 100)",
          "format": "table",
          "instant": true
        },
        {
          "refId": "E",
          "expr": "(1 - (node_memory_MemAvailable_bytes{job=\"node\", server=~\"$server\", instance=~\"$instance\"} / node_memory_MemTotal_bytes{job=\"node\", server=~\"$server\", instance=~\"$instance\"})) * 100",
          "format": "table",
          "instant": true
        },
        {
          "refId": "F",
          "expr": "100 * (1 - (node_filesystem_avail_bytes{job=\"node\", server=~\"$server\", instance=~\"$instance\", mountpoint=\"/\", fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{job=\"node\", server=~\"$server\", instance=~\"$instance\", mountpoint=\"/\", fstype!~\"tmpfs|overlay\"}))",
          "format": "table",
          "instant": true
        },
        {
          "refId": "G",
          "expr": "sum by (server,host,instance) (rate(node_disk_read_bytes_total{job=\"node\", server=~\"$server\", instance=~\"$instance\", device!~\"loop.*|ram.*\"}[5m]))",
          "format": "table",
          "instant": true
        },
        {
          "refId": "H",
          "expr": "sum by (server,host,instance) (rate(node_disk_written_bytes_total{job=\"node\", server=~\"$server\", instance=~\"$instance\", device!~\"loop.*|ram.*\"}[5m]))",
          "format": "table",
          "instant": true
        },
        {
          "refId": "I",
          "expr": "100 * (1 - (node_memory_SwapFree_bytes{job=\"node\", server=~\"$server\", instance=~\"$instance\"} / node_memory_SwapTotal_bytes{job=\"node\", server=~\"$server\", instance=~\"$instance\"}))",
          "format": "table",
          "instant": true
        },
        {
          "refId": "J",
          "expr": "node_time_seconds{job=\"node\", server=~\"$server\", instance=~\"$instance\"} - node_boot_time_seconds{job=\"node\", server=~\"$server\", instance=~\"$instance\"}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "K",
          "expr": "100 * node_load1{job=\"node\", server=~\"$server\", instance=~\"$instance\"} / (count by (server,host,instance) (node_cpu_seconds_total{job=\"node\", server=~\"$server\", instance=~\"$instance\", mode=\"idle\"}))",
          "format": "table",
          "instant": true
        },
        {
          "refId": "L",
          "expr": "100 * node_load5{job=\"node\", server=~\"$server\", instance=~\"$instance\"} / (count by (server,host,instance) (node_cpu_seconds_total{job=\"node\", server=~\"$server\", instance=~\"$instance\", mode=\"idle\"}))",
          "format": "table",
          "instant": true
        },
        {
          "refId": "M",
          "expr": "100 * node_load15{job=\"node\", server=~\"$server\", instance=~\"$instance\"} / (count by (server,host,instance) (node_cpu_seconds_total{job=\"node\", server=~\"$server\", instance=~\"$instance\", mode=\"idle\"}))",
          "format": "table",
          "instant": true
        }
      ],
