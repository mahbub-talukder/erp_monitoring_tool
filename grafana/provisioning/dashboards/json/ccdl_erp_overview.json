              "Time": true
            },
            "renameByName": {
              "server": "Server",
              "host": "Host",
              "instance": "Instance",
              "Value #A": "Server Alive",
              "Value #B": "Docker",
              "Value #C": "CPU",
              "Value #D": "RAM",
              "Value #E": "Disk usage",
              "Value #F": "Uptime"
