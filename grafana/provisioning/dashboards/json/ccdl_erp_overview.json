    {
      "id": 33,
      "type": "gauge",
      "title": "Max Replica Lag (MB)",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 11
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(clamp_min((scalar(max(patroni_xlog_location{job=\"patroni_odoo\"})) - max by (name) (patroni_xlog_replayed_location{job=\"patroni_odoo\"} and on (name) (patroni_replica{job=\"patroni_odoo\"} == 1))) / 1024 / 1024, 0))",
          "legendFormat": "lag"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "min": 0,
          "max": 500,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 50,
                "color": "orange"
              },
              {
                "value": 100,
                "color": "red"
              }
            ]
          }
